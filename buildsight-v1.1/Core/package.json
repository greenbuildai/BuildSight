{
  "name": "buildsight",
  "private": true,
  "workspaces": [
    "frontend"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:frontend": "npm --prefix frontend run dev -- --host 0.0.0.0 --port 5173",
    "dev:backend": "python -m uvicorn backend.main:app --reload --host 0.0.0.0 --port 8000"
  },
  "devDependencies": {
    "concurrently": "^9.0.1"
  }
}

