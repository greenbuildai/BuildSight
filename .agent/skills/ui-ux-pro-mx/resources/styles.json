      "attributes": {
        "blur": "16px",
        "opacity": "0.7",
        "border": "1px solid rgba(255,255,255,0.1)"
      }
    },
    {
      "id": "neumorphism",
      "name": "Neumorphism",
      "description": "Soft shadows and highlights creating an extruded plastic look.",
