{
  "version": "1.0.0",
  "products": [
    {
      "id": "fintech",
      "name": "Fintech",
      "tags": ["finance", "trust", "metrics", "dark"],
      "recommended_styles": ["glassmorphism", "oled-dark"],
      "recommended_palettes": ["fintech-night", "fintech-day"],
      "recommended_fonts": ["space-grotesk", "inter"],
      "recommended_charts": ["candlestick", "area", "kpi-cards"],
      "recommended_patterns": ["hero-metrics-cta", "sticky-command-rail"],
      "ux_notes": [
        "Keep risk and profit signals visually separated.",
        "Use reduced motion for charts and live price transitions.",
        "Surface trust indicators before conversion actions."
      ]
    },
    {
      "id": "saas",
      "name": "SaaS",
      "tags": ["b2b", "clean", "conversion", "light"],
      "recommended_styles": ["minimalism", "aurora-ui"],
      "recommended_palettes": ["saas-light", "saas-dark"],
      "recommended_fonts": ["sora", "inter"],
      "recommended_charts": ["line", "bar", "kpi-cards"],
      "recommended_patterns": ["hero-proof-cta", "feature-grid"],
      "ux_notes": [
        "Make the primary CTA visible above the fold.",
        "Prioritize clarity over density in pricing and feature comparison.",
        "Keep dashboard summaries scannable in under five seconds."
      ]
    },
    {
      "id": "geoai",
      "name": "GeoAI",
      "tags": ["industrial", "mapping", "operations", "dark"],
      "recommended_styles": ["glassmorphism", "tactical-hud", "oled-dark"],
      "recommended_palettes": ["command-center", "industrial-dawn"],
      "recommended_fonts": ["space-grotesk", "jetbrains-mono"],
      "recommended_charts": ["heatmap", "timeline", "kpi-cards"],
      "recommended_patterns": ["mission-control", "map-telemetry-split"],
      "ux_notes": [
        "Keep the map dominant and reserve side rails for actions and telemetry.",
        "Use contrast and shape, not only color, for critical alerts.",
        "Avoid cluttering the map with more than three simultaneous overlays."
      ]
    }
  ],
  "styles": [
    {
      "id": "glassmorphism",
      "name": "Glassmorphism",
      "description": "Translucent layers with restrained blur for tactical or premium surfaces.",
      "tags": ["modern", "premium", "dark", "tactical"],
      "products": ["fintech", "geoai"],
      "themes": ["dark"],
      "attributes": {
        "blur": "16px",
        "surface": "rgba(17, 19, 20, 0.72)",
        "border": "1px solid rgba(255,255,255,0.08)"
      }
    },
    {
      "id": "oled-dark",
      "name": "OLED Dark",
      "description": "True-black foundations with bright telemetry accents and high signal separation.",
      "tags": ["dark", "premium", "contrast"],
